# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/audiostreamer

# ─────────────────────────────────────────────
# JWT
# Generate: openssl rand -hex 32
# ─────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─────────────────────────────────────────────
# Addon settings encryption (Fernet)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ─────────────────────────────────────────────
FERNET_KEY=change-me-generate-with-fernet

# ─────────────────────────────────────────────
# CORS — JSON array of allowed origins
# ─────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
ENVIRONMENT=development

# ─────────────────────────────────────────────
# Local Files Addon
# Server-side path where audiobooks are stored
# Expected layout: {LIBRARY_PATH}/Author/Book Title/chapter.mp3
# ─────────────────────────────────────────────
LOCAL_FILES_LIBRARY_PATH=/path/to/audiobooks
